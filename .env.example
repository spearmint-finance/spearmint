# Docker Compose Port Configuration
# Copy this file to .env and customize ports to avoid conflicts
# with other running instances (e.g., dev container vs local desktop)

# API Gateway port (main entry point)
GATEWAY_PORT=8080

# Web App port (Vite dev server)
WEB_PORT=5173

# MCP Server port (AI agent integration)
MCP_PORT=3001

# PostgreSQL port
DB_PORT=5432

# ================================================================
# EXAMPLE: Running on different ports to avoid conflicts
# ================================================================
# If the dev container uses default ports, set these for local:
#   GATEWAY_PORT=8090
#   WEB_PORT=5183
#   MCP_PORT=3011
#   DB_PORT=5442
# ================================================================

# Postman API Configuration (for API validation scripts)
POSTMAN_API_KEY=your-postman-api-key-here
POSTMAN_WORKSPACE_ID=your-workspace-id-here
