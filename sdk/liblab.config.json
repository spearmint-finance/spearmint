{
  "sdkName": "spearmint-api",
  "apiVersion": "0.1.0",
  "apiName": "spearmint-api",
  "specFilePath": "./openapi.json",
  "languages": [
    "typescript",
    "python"
  ],
  "auth": [
    "bearer"
  ],
  "customizations": {
    "includeOptionalSnippetParameters": true,
    "authentication": {
      "access": {
        "prefix": "Bearer"
      }
    },
    "devContainer": true,
    "generateEnv": true,
    "inferServiceNames": false,
    "injectedModels": [],
    "license": {
      "type": "MIT"
    },
    "responseHeaders": true,
    "retry": {
      "enabled": true,
      "maxAttempts": 3,
      "retryDelay": 150
    }
  },
  "mcp": {
    "generate": false
  },
  "languageOptions": {
    "typescript": {
      "npmOrg": "spearmint-finance",
      "npmName": "sdk"
    }
  },
  "publishing": {
    "githubOrg": ""
  }
}
