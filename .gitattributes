# Default: auto-detect text files and normalize to LF
* text=auto eol=lf

# Explicitly declare text files to always use LF (critical for Linux containers)
*.sh text eol=lf
*.bash text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Devcontainer files must always be LF
.devcontainer/** text eol=lf

# Denote binary files that should not be modified
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
