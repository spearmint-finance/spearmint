# Database Configuration
DATABASE_URL=sqlite:///financial_analysis.db

# Application Settings
APP_ENV=development
DEBUG=True

# Data Import Settings
DEFAULT_IMPORT_PATH=data/transactions.xlsx

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API Validation Configuration
# These are used by scripts/api_validation/ tools

# Postman API Configuration
# Get your API key from: https://go.postman.co/settings/me/api-keys
POSTMAN_API_KEY=your-postman-api-key-here

# Get your workspace ID from your Postman workspace URL
# Example: https://www.postman.com/workspace/my-workspace-abc123def456
# The workspace ID is the part after /workspace/
POSTMAN_WORKSPACE_ID=your-workspace-id-here

# Optional: Spectral CLI Configuration
# Spectral CLI is installed via npm, no environment variables needed
# To install: npm install (from repository root)
# To verify: npx @stoplight/spectral-cli --version
