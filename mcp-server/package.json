{
  "name": "@spearmint-finance/mcp-server",
  "version": "0.0.1",
  "description": "MCP Server for Spearmint Finance - enables AI agent integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:tools": "tsx scripts/generate-tools.ts",
    "generate:tools:dry-run": "tsx scripts/generate-tools.ts --dry-run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "finance",
    "spearmint"
  ],
  "author": "Spearmint Finance",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
