# spearmint/web-app/Dockerfile.dev
# Development Dockerfile with hot reload

FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY web-app/package.json web-app/package-lock.json ./

# Install dependencies
RUN npm install

# Copy source code (will be overridden by volume mount)
# Note: node_modules excluded via .dockerignore
COPY web-app/src ./src
COPY web-app/public ./public
COPY web-app/index.html web-app/vite.config.ts web-app/tsconfig*.json ./

# Expose Vite dev server port
EXPOSE 5173

# Run Vite dev server with hot reload
# --host 0.0.0.0 allows access from outside container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

