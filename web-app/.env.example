# API Configuration
# For local development with Vite proxy (recommended):
# Leave VITE_API_URL unset to use window.location.origin (http://localhost:5173)
# This routes through Vite's proxy to Core API, similar to production gateway
# VITE_API_URL=

# Alternative: Direct API access (bypasses Vite proxy):
# VITE_API_URL=http://localhost:8000/api

# For Docker development (routes through API Gateway):
# VITE_API_URL=http://localhost:8080

